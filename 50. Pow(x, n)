class Solution:
    def myPow(self, x: float, n: int) -> float:
        if n == 0:
            return 1.0

        negative = False
        if n < 0:
            negative = True
            n = -n

        result = 1.0

        for _ in range(n):
            result *= x

        if negative:
            return 1 / result

        return result

