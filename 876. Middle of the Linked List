class Solution:
    def middleNode(self, head: Optional[ListNode]) -> Optional[ListNode]:
        length = 0
        temp = head

        while temp:
            length += 1
            temp = temp.next

        mid = length // 2
        temp = head

        for _ in range(mid):
            temp = temp.next

        return temp

