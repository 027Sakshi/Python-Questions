class Solution:
    def deleteDuplicates(self, head: Optional[ListNode]) -> Optional[ListNode]:
        freq = {}
        temp = head

        while temp:
            freq[temp.val] = freq.get(temp.val, 0) + 1
            temp = temp.next

        dummy = ListNode(0)
        curr = dummy

        while head:
            if freq[head.val] == 1:
                curr.next = ListNode(head.val)
                curr = curr.next
            head = head.next

        return dummy.next
