class Solution:
    def rotateRight(self, head: Optional[ListNode], k: int) -> Optional[ListNode]:
        if not head or not head.next:
            return head

        length = 0
        temp = head
        while temp:
            length += 1
            temp = temp.next

        k %= length

        for _ in range(k):
            prev = None
            curr = head

            while curr.next:
                prev = curr
                curr = curr.next

            prev.next = None
            curr.next = head
            head = curr

        return head
